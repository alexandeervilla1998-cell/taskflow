# Variables de entorno requeridas para el perfil de produccion
# Copiar este archivo como .env y completar los valores reales

# Base de datos MySQL
DB_URL=jdbc:mysql://localhost:3306/taskflow?useSSL=true&requireSSL=true
DB_USERNAME=taskflow_user
DB_PASSWORD=your_secure_password_here

# JWT Secret (minimo 32 caracteres, usar un valor aleatorio seguro)
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_minimum_32_chars

# URL del frontend (para CORS)
FRONTEND_URL=https://tu-dominio.com

# Activar perfil de produccion
SPRING_PROFILES_ACTIVE=prod
